{
  "name": "verin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:fitness": "vitest run src/__tests__/fitness",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "knip": "knip",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "audit:chain": "tsx scripts/audit-chain-verify.ts",
    "license:audit": "tsx scripts/license-audit.ts",
    "load:smoke": "tsx scripts/load-smoke.ts",
    "sbom": "cdxgen -t pnpm --no-install-deps -o sbom.json ."
  },
  "dependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-node": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "geist": "1.7.2",
    "next": "16.2.10",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver",
      "sharp",
      "libxmljs2",
      "@tailwindcss/oxide"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@cyclonedx/cdxgen": "12.8.0",
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "axe-core": "4.12.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "knip": "6.27.0",
    "pino-pretty": "13.1.3",
    "postcss": "8.5.20",
    "tailwindcss": "4.3.3",
    "ts-morph": "28.0.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
