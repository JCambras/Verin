# Verin environment template — PLACEHOLDER VALUES ONLY.
#
# Charter non-negotiable #7: this file must never contain a real secret, live org
# domain, username, or credential. CI fails the build if it does (see the
# no-secret-fallback / no-live-org-domain fence). Copy to `.env.local` and fill in
# real values locally; never commit the filled copy.
#
# Every key here is read ONLY by src/infrastructure/config (charter #7, fence:
# no-process-env). No other module may read process.env.

# --- Runtime ---
NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:3000
# IANA timezone of the operating firm. Never hardcoded in source.
FIRM_TIMEZONE=America/New_York

# --- House-CRM store (charter: PostgreSQL behind the store port) ---
# Driver selects the adapter behind StorePort. "pglite" = embedded Postgres
# (dev/CI, durable to VERIN_DATA_DIR). "postgres" = managed Postgres via DATABASE_URL.
VERIN_STORE_DRIVER=pglite
VERIN_DATA_DIR=.verin-data
# Only used when VERIN_STORE_DRIVER=postgres. Placeholder — never a live DSN.
DATABASE_URL=postgres://USER:CHANGEME_PASSWORD@HOST:5432/verin

# --- Identity / sessions (charter #12: real auth, no secret fallbacks) ---
# 32+ char random secret. Generate with: openssl rand -base64 48
SESSION_SECRET=CHANGEME_generate_a_32plus_char_random_secret
SESSION_TTL_MINUTES=60

# --- Simulated e-sign webhook (charter deliverable E) ---
# HMAC secret the webhook uses to authenticate the fire-and-return callback.
ESIGN_WEBHOOK_SECRET=CHANGEME_generate_a_32plus_char_random_secret

# --- Observability (charter #14) ---
LOG_LEVEL=info
OTEL_SERVICE_NAME=verin
# Optional OTLP endpoint; unset => in-process/console span export in dev.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
